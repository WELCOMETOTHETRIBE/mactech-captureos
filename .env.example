# ----- Core infra (local dev via docker-compose) -----
DATABASE_URL=postgresql+asyncpg://mactech:mactech@localhost:5432/mactech
DATABASE_URL_SYNC=postgresql+psycopg://mactech:mactech@localhost:5432/mactech
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mactech-documents

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@mactechsolutionsllc.com

# Resend transactional email
RESEND_API_KEY=
RESEND_FROM=MacTech CaptureOS <digest@mactechsolutionsllc.com>
RESEND_REPLY_TO=

# Public base URL of the web app. Used to build deep links in outbound
# email (e.g. the digest's "Review in CaptureOS" bid-invite links), so it
# must be reachable from a mail client, not an internal hostname.
APP_BASE_URL=https://capture.mactechsolutionsllc.com

# ----- Tenant identity -----
# Set after MacTech tenant is seeded; kept stable across environments so workers can scope jobs.
MACTECH_TENANT_SLUG=mactech

# ----- External APIs -----
SAM_API_KEY=
APIFY_API_TOKEN=
SERPAPI_KEY=

# ----- Inbound email (Postmark) -----
# Shared secret Postmark presents as basic-auth in the inbound webhook URL:
#   https://postmark:<secret>@<api-host>/webhooks/postmark/inbound
# Generate with: openssl rand -hex 32
POSTMARK_WEBHOOK_SECRET=

# Anthropic: single platform key for Phase 1. All MacTech LLM traffic goes through this.
# Set a $75/mo spend alert in the Anthropic console.
ANTHROPIC_API_KEY=

VOYAGE_API_KEY=
OPENAI_API_KEY=

# ----- Auth (Clerk) — wired in Phase 2 Week 5 -----
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_KEY=

# ----- Observability -----
SENTRY_DSN=
POSTHOG_API_KEY=
LOG_LEVEL=INFO
ENVIRONMENT=development
